{
  "name": "agentic-test",
  "version": "0.1.0",
  "description": "A lightweight, Jest-like testing framework for AI agent workflows. Test tool calls, outputs, latency, and costs with a familiar describe/test API.",
  "author": "Satyam Das <satyamdas03@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./assertions": {
      "types": "./dist/assertions.d.ts",
      "import": "./dist/assertions.js",
      "require": "./dist/assertions.cjs"
    }
  },
  "bin": {
    "agentic-test": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "testing",
    "llm",
    "langchain",
    "openai",
    "evaluation",
    "test-framework",
    "tool-calling",
    "assertions",
    "ci-cd",
    "multi-agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/satyamdas03/agentic-test"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}