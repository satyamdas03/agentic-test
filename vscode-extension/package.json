{
    "name": "agentic-test-vscode",
    "displayName": "agentic-test",
    "description": "Run and visualize agentic-test workflows directly inside VS Code",
    "version": "1.0.0",
    "publisher": "satyamdas",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Testing"
    ],
    "activationEvents": [
        "onLanguage:typescript",
        "onLanguage:javascript"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "agentic-test.runAll",
                "title": "Agentic Test: Run All Tests"
            },
            {
                "command": "agentic-test.runTest",
                "title": "Agentic Test: Run Test"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run package",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
        "esbuild": "npm run package",
        "esbuild-watch": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^7.0.0",
        "@typescript-eslint/parser": "^7.0.0",
        "esbuild": "^0.20.0",
        "eslint": "^8.0.0",
        "typescript": "^5.0.0"
    }
}